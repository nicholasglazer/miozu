#!/usr/bin/env python3
"""
domain-sweep — parallel domain-availability sweeper via registry RDAP.

Queries registry RDAP endpoints directly (Verisign for .com/.net, Identity
Digital for .ai and many others). 200=registered, 404=available, 429=throttled.

KNOWN LIMITATION: RDAP 404 does NOT guarantee the domain is registerable.
Registry-reserved names (ICANN-held acronyms like GNSO/IESG/IANA; ccTLD
collision strings; certain geographic terms) return 404 but cannot be
purchased. Always post-verify hits at a registrar (Porkbun, Namecheap,
Cloudflare) before assuming a name is buyable.

Examples:
  # Every 4-letter .com (exhaustive, 456,976 queries)
  domain-sweep --length 4 --alpha --tld com --output com4.csv

  # Japanese-flavor 4L .ai from a wordlist
  domain-sweep --file words.txt --tld ai --available-only

  # Resume an interrupted sweep
  domain-sweep --length 4 --alpha --tld com --output com4.csv --resume

  # Random sample
  domain-sweep --length 4 --alphanum --tld com --sample 5000 --seed 42
"""
from __future__ import annotations
import argparse, csv, itertools, random, signal, sys, time, urllib.request, urllib.error
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path

# --- RDAP endpoints ---------------------------------------------------------
# Direct registry endpoints are faster and less rate-limited than rdap.org.
RDAP = {
    "com": "https://rdap.verisign.com/com/v1/domain/{}",
    "net": "https://rdap.verisign.com/net/v1/domain/{}",
    "ai":  "https://rdap.identitydigital.services/rdap/domain/{}",
    "io":  "https://rdap.identitydigital.services/rdap/domain/{}",
    "sh":  "https://rdap.identitydigital.services/rdap/domain/{}",
    "dev": "https://www.registry.google/rdap/domain/{}",
    "app": "https://www.registry.google/rdap/domain/{}",
}
RDAP_FALLBACK = "https://rdap.org/domain/{}"

# --- Pattern generators ------------------------------------------------------
def gen_exhaustive(length: int, charset: str):
    for p in itertools.product(charset, repeat=length):
        yield "".join(p)

def gen_pronounceable(length: int):
    V, C = "aeiou", "bcdfghjklmnprstvwyz"
    if length == 3:
        for a,b,c in itertools.product(C,V,C): yield a+b+c
    elif length == 4:
        for a,b,c,d in itertools.product(C,V,C,V): yield a+b+c+d
        for a,b,c,d in itertools.product(V,C,V,C): yield a+b+c+d
    else:
        for p in itertools.product(C+V, repeat=length): yield "".join(p)

# --- Lookup ------------------------------------------------------------------
def lookup(domain: str, tld: str, timeout: float = 8.0, max_retries: int = 5) -> int:
    url = RDAP.get(tld, RDAP_FALLBACK).format(domain)
    req = urllib.request.Request(url, headers={"Accept": "application/rdap+json"})
    delay = 1.0
    for attempt in range(max_retries):
        try:
            with urllib.request.urlopen(req, timeout=timeout) as r:
                return r.getcode()
        except urllib.error.HTTPError as e:
            # Rate limit signals — back off and retry
            if e.code in (403, 429, 503):
                time.sleep(delay + random.random() * 0.5)
                delay = min(delay * 2, 30.0)
                continue
            return e.code
        except Exception:
            time.sleep(delay)
            delay = min(delay * 2, 15.0)
            continue
    return 0  # exhausted retries

def status_label(code: int) -> str:
    return {200: "taken", 404: "available", 403: "throttled",
            429: "throttled", 0: "error"}.get(code, f"http_{code}")

# --- Sweeper -----------------------------------------------------------------
def sweep(domains, tld: str, parallel: int, outfile, available_only: bool,
          resume_set: set, progress_every: int = 500):
    stop = {"flag": False}
    def handle_sigint(sig, frm):
        stop["flag"] = True
        print("\n[stopping — partial results written]", file=sys.stderr)
    signal.signal(signal.SIGINT, handle_sigint)

    writer = csv.writer(outfile)
    if outfile is not sys.stdout and outfile.tell() == 0:
        writer.writerow(["domain", "status_code", "status"])
    outfile.flush()

    start = time.monotonic()
    total = 0
    available = 0
    throttled = 0

    def work(stem):
        full = f"{stem}.{tld}"
        code = lookup(full, tld)
        return full, code

    with ThreadPoolExecutor(max_workers=parallel) as pool:
        pending = {}
        it = iter(domains)
        # Prime
        for _ in range(parallel * 2):
            try: s = next(it)
            except StopIteration: break
            if f"{s}.{tld}" in resume_set: continue
            pending[pool.submit(work, s)] = s

        while pending and not stop["flag"]:
            for fut in as_completed(list(pending)):
                stem = pending.pop(fut)
                try:
                    full, code = fut.result()
                except Exception:
                    continue
                total += 1
                if code == 404: available += 1
                elif code == 429: throttled += 1
                if (not available_only) or code == 404:
                    writer.writerow([full, code, status_label(code)])
                    # Flush on every 404 (rare) or every 50 general rows
                    if code == 404 or total % 50 == 0:
                        outfile.flush()
                if total % progress_every == 0:
                    elapsed = time.monotonic() - start
                    rate = total / elapsed if elapsed else 0
                    print(f"[{total} checked | {available} free | {throttled} throttled | {rate:.1f}/s]",
                          file=sys.stderr)
                # Queue next
                if stop["flag"]: break
                try: s = next(it)
                except StopIteration: continue
                if f"{s}.{tld}" in resume_set: continue
                pending[pool.submit(work, s)] = s
                break  # re-enter as_completed loop to keep pool full

    outfile.flush()
    elapsed = time.monotonic() - start
    print(f"\n[done] {total} checked · {available} available · {throttled} throttled · {elapsed:.1f}s",
          file=sys.stderr)

# --- CLI --------------------------------------------------------------------
def main():
    ap = argparse.ArgumentParser(description="Parallel domain-availability sweeper (RDAP).",
                                 formatter_class=argparse.RawDescriptionHelpFormatter,
                                 epilog=__doc__)
    src = ap.add_mutually_exclusive_group(required=True)
    src.add_argument("--length", type=int, help="Stem length for exhaustive sweep")
    src.add_argument("--file", type=Path, help="File with one domain stem per line")
    src.add_argument("--stdin", action="store_true", help="Read stems from stdin")

    ap.add_argument("--tld", default="com", help="TLD (default: com)")
    ap.add_argument("--charset", default=None,
                    help="Custom charset for exhaustive (default: a-z)")
    ap.add_argument("--alpha", action="store_true", help="Shortcut: charset=a-z")
    ap.add_argument("--alphanum", action="store_true", help="Shortcut: charset=a-z0-9")
    ap.add_argument("--pronounceable", action="store_true",
                    help="Generate pronounceable stems (C/V patterns)")

    ap.add_argument("--parallel", type=int, default=15, help="Parallel workers (default: 15)")
    ap.add_argument("--sample", type=int, default=0,
                    help="Randomly sample N stems from generator")
    ap.add_argument("--seed", type=int, default=None, help="Random seed for --sample")

    ap.add_argument("--output", type=str, default="-",
                    help="CSV output path (default: stdout)")
    ap.add_argument("--available-only", action="store_true",
                    help="Only log 404 (available) domains")
    ap.add_argument("--resume", action="store_true",
                    help="Skip domains already in --output")

    args = ap.parse_args()

    # Resolve charset
    if args.alpha: charset = "abcdefghijklmnopqrstuvwxyz"
    elif args.alphanum: charset = "abcdefghijklmnopqrstuvwxyz0123456789"
    elif args.charset: charset = args.charset
    else: charset = "abcdefghijklmnopqrstuvwxyz"

    # Build generator
    if args.length is not None:
        if args.pronounceable:
            gen = gen_pronounceable(args.length)
        else:
            gen = gen_exhaustive(args.length, charset)
    elif args.file:
        gen = (l.strip().split(".")[0] for l in args.file.read_text().splitlines() if l.strip())
    elif args.stdin:
        gen = (l.strip().split(".")[0] for l in sys.stdin if l.strip())

    if args.sample:
        pool = list(gen)
        rng = random.Random(args.seed)
        rng.shuffle(pool)
        gen = iter(pool[:args.sample])

    # Resume set
    resume_set = set()
    if args.resume and args.output != "-":
        p = Path(args.output)
        if p.exists():
            with p.open() as f:
                r = csv.reader(f)
                next(r, None)
                for row in r:
                    if row: resume_set.add(row[0])
            print(f"[resume] skipping {len(resume_set)} already-checked", file=sys.stderr)

    # Output handle
    if args.output == "-":
        out = sys.stdout
    else:
        out = open(args.output, "a", newline="")

    try:
        sweep(gen, args.tld, args.parallel, out, args.available_only, resume_set)
    finally:
        if out is not sys.stdout: out.close()

if __name__ == "__main__":
    main()
